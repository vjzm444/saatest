@page "/quiz"
@using AppBase;
@using AppBase.Redis;
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@inject RedisDatabase redisDatabase


<div class="container-fluid mt-4">
    @* 상단 컨트롤 바 *@
    <div class="d-flex justify-content-between align-items-center mb-4 sticky-top bg-white py-2 shadow-sm px-3" style="z-index: 1020; top: 0;">
        <h3 class="mb-0 text-primary">SAA 실전 문제 (@currentPage / @TotalPages Page)</h3>

        <div class="d-flex align-items-center gap-2">
            @* 셔플 버튼 추가 *@
            <button class="btn btn-warning btn-sm me-2" @onclick="ShuffleQuestions">
                <i class="bi bi-shuffle"></i> 문제 섞기
            </button>

            @* 페이지 이동 컨트롤 *@
            <div class="btn-group me-3">
                <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage == 1)" @onclick="() => ChangePage(currentPage - 1)">이전</button>
                <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage == TotalPages)" @onclick="() => ChangePage(currentPage + 1)">다음</button>
            </div>

            @* 특정 문제 번호로 점프 *@
            <div class="input-group" style="width: 180px;">
                <input type="number" class="form-control form-control-sm" placeholder="Q 번호"
                       @bind="jumpTarget" @onkeyup="HandleKeyUp" />
                <button class="btn btn-primary btn-sm" @onclick="JumpToQuestion">이동</button>
            </div>
        </div>
    </div>

    @if (questions == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status"></div>
            <p>CSV 파일에서 1,000개의 문제를 읽어오는 중...</p>
        </div>
    }
    else
    {
        @* 페이징된 데이터만 출력 *@
        @foreach (var q in PagedQuestions)
        {
            <div id="question-@q.Id" class="card mb-4 shadow-sm border-secondary">
                <div class="card-body">
                    <h5 class="card-title">Q@(q.Id). @q.Title</h5>

                    <div class="list-group mt-3">
                        @foreach (var opt in q.Options)
                        {
                            <label class="list-group-item d-flex justify-content-between align-items-start" style="cursor: pointer; min-height: 50px;">
                                <div class="flex-grow-1 me-3">
                                    <span class="fw-bold">@opt.Key.</span> @opt.Value
                                </div>

                                @* 핵심: flex-shrink-0(안 찌그러지게), align-self-start(위로 고정) *@
                                <input type="radio"
                                   name="question-@q.Id"
                                   class="form-check-input flex-shrink-0 mt-1"
                                   style="width: 1.25rem; height: 1.25rem; align-self: start;"
                                   checked="@(q.SelectedKey == opt.Key)"
                                   onclick="saveAnswer(@q.Id, '@opt.Key')" />
                            </label>
                        }
                    </div>

                    @* 오프라인 생존형 버튼 (onclick 사용) *@
                    <div class="mt-3">
                        <div class="pure-js-btn btn btn-primary w-100"
                             onclick="toggleAnswer(this)"
                             style="cursor: pointer;">
                            정답 확인
                        </div>
                    </div>

                    @* 해설 섹션 *@
                    <div class="answer-section" style="display: none;">
                        <hr />
                        <div class="alert alert-info">
                            <strong>정답: @q.CorrectKey</strong><br />
                            @q.Explanation
                        </div>
                    </div>
                </div>
            </div>
        }

        @* 하단 페이지네이션 *@
        <div class="d-flex justify-content-center mt-4 mb-5">
            <div class="btn-group">
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(TotalPages, currentPage + 2); i++)
                {
                    int pageNum = i;
                    <button class="btn @(currentPage == pageNum ? "btn-primary" : "btn-outline-primary")"
                            @onclick="() => ChangePage(pageNum)">
                        @pageNum
                    </button>
                }

            </div>
            
            <button class="btn btn-danger btn-sm" @onclick="SaveWrongQuestions">
                <i class="bi bi-bug"></i> 틀린 문제 저장
            </button>
            <button class="btn btn-secondary btn-sm ms-2" @onclick="ResetAll">
                <i class="bi bi-trash"></i> 리셋하기
            </button>
        </div>

    }
</div>

@code {
    private List<QuestionModel>? questions;
    private int jumpTarget;

    // 페이징 설정
    private int currentPage = 1;
    private int pageSize = 50;

    // LINQ로 현재 페이지 데이터 슬라이싱
    private IEnumerable<QuestionModel> PagedQuestions =>
        questions?.Skip((currentPage - 1) * pageSize).Take(pageSize) ?? Enumerable.Empty<QuestionModel>();

    private int TotalPages => questions == null ? 0 : (int)Math.Ceiling((double)questions.Count / pageSize);


    //CSV를 읽어들인다
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var absoluteUri = NavManager.ToAbsoluteUri("data/questions2.csv").ToString();
            var csvData = await Http.GetStringAsync(absoluteUri);
            var lines = csvData.Split('\n').Skip(1);

            questions = new List<QuestionModel>();
            foreach (var line in lines)
            {
                if (string.IsNullOrWhiteSpace(line)) continue;
                var cols = line.Split(',');
                if (cols.Length < 8) continue;

                questions.Add(new QuestionModel
                    {
                        Id = int.Parse(cols[0]),
                        Title = cols[1],
                        Options = new Dictionary<string, string> {
                        { "A", cols[2] }, { "B", cols[3] }, { "C", cols[4] }, { "D", cols[5] }
                    },
                        CorrectKey = cols[6].Trim(),
                        Explanation = cols[7]
                    });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"CSV 로딩 실패: {ex.Message}");
        }
    }

    
    private bool _loadedFromStorage = false;
    //브라우저 스토리지에 풀다만것들을 조회한다
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_loadedFromStorage && questions != null)
        {
            _loadedFromStorage = true;

            var savedAnswers = await JSRuntime.InvokeAsync<Dictionary<string, string>>("quizStorage.loadAnswers");

            Console.WriteLine("🔥 LOAD FROM STORAGE 실행됨");

            if (savedAnswers != null)
            {
                foreach (var q in questions)
                {
                    if (savedAnswers.TryGetValue(q.Id.ToString(), out var savedKey))
                    {
                        q.SelectedKey = savedKey;
                    }
                }
            }

            StateHasChanged();
        }
    }

    private async Task ChangePage(int page)
    {
        currentPage = Math.Clamp(page, 1, TotalPages);

        // 페이지 바뀔 때 JS 호출해서 UI 싹 닫기
        await JSRuntime.InvokeVoidAsync("resetAnswers");

        // 스크롤도 맨 위로
        await JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);

        StateHasChanged();
    }

    //문제를 고를때마다 브라우저 스토리지에 저장된다
    private async Task OnSelectAnswer(QuestionModel q, string key)
    {
        q.SelectedKey = key;

        // 👉 여기서 JS 호출해야 저장됨
        await JSRuntime.InvokeVoidAsync("quizStorage.saveAnswer", q.Id, key);
    }

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await JumpToQuestion();
    }

    private async Task JumpToQuestion()
    {
        if (questions == null || jumpTarget <= 0) return;

        // 1. 해당 문제가 속한 페이지 계산
        int targetPage = (int)Math.Ceiling((double)jumpTarget / pageSize);

        // 2. 페이지 이동
        if (currentPage != targetPage)
        {
            currentPage = targetPage;
            StateHasChanged(); // UI 강제 갱신
            await Task.Delay(100); // 렌더링 시간 확보
        }

        // 3. 해당 요소로 스크롤
        await JSRuntime.InvokeVoidAsync("scrollToElement", $"question-{jumpTarget}");
    }

    private async Task ResetAll()
    {
        // 1. localStorage 삭제
        await JSRuntime.InvokeVoidAsync("clearQuizStorage");

        // 2. UI 초기화 (해설 접기)
        await JSRuntime.InvokeVoidAsync("resetAnswers");

        // 3. Blazor 상태 초기화
        if (questions != null)
        {
            foreach (var q in questions)
            {
                q.SelectedKey = "";
            }
        }

        StateHasChanged();
    }


    //문제셔플
    private void ShuffleQuestions()
    {
        if (questions == null || !questions.Any()) return;

        // 8년 차의 깔끔한 셔플 로직 (LINQ 활용)
        var rnd = new Random();
        questions = questions.OrderBy(x => rnd.Next()).ToList();

        // 섞은 후에는 1페이지로 이동하고 상태 갱신
        currentPage = 1;
        StateHasChanged();
        JSRuntime.InvokeVoidAsync("window.scrollTo", 0, 0);
    }

    private async Task SaveWrongQuestions()
    {
        if (questions == null) return;

        // 1. 틀린 문제만 필터링 (선택을 했고 + 정답과 다른 경우)
        var wrongQuestions = questions
            .Where(q => !string.IsNullOrEmpty(q.SelectedKey) && q.SelectedKey != q.CorrectKey)
            .ToList();

        if (!wrongQuestions.Any())
        {
            await JSRuntime.InvokeVoidAsync("alert", "저장할 틀린 문제가 없습니다!");
            return;
        }

        try
        {
            // 2. Redis 서비스 가져오기 (Blazor Server 기준 inject 혹은 의존성 주입 확인)
            // 만약 OnInitialized에서 가져온다면 해당 변수를 사용해.
        

            RedisDatabaseWrapper redisDb = redisDatabase!.GetDatabase();
        
            if (redisDb == null) return;

            foreach (var q in wrongQuestions)
            {
                // 3. Key는 Q50 형식, Value는 +1 (Incr)
                string redisKey = $"Q{q.Id}";
            
                await redisDb.StringIncrementAsync(redisKey, 1); // 1씩 증가
            }

            await JSRuntime.InvokeVoidAsync("alert", $"{wrongQuestions.Count}개의 틀린 문제를 Redis에 저장(누적)했습니다!");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Redis 저장 실패: {ex.Message}");
            await JSRuntime.InvokeVoidAsync("alert", "Redis 저장 중 오류가 발생했습니다.");
        }

    }

    public class QuestionModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public Dictionary<string, string> Options { get; set; } = new();
        public string CorrectKey { get; set; } = "";
        public string Explanation { get; set; } = "";
        public string SelectedKey { get; set; } = "";
        public bool IsSubmitted { get; set; } = false;
    }
}