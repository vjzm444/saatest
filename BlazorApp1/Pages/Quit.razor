@page "/quiz"
@using AppBase;
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime

<div class="container-fluid mt-4">
    @* 상단 컨트롤 바: 사이드바 토글 및 5번 이동 버튼 *@
    <div class="d-flex justify-content-between align-items-center mb-4 sticky-top bg-white py-2 shadow-sm px-3" style="z-index: 1020; top: 0;">
        <h3 class="mb-0 text-primary">SAA 실전 문제</h3>
        <div class="d-flex align-items-center">
            @* 문제 번호 입력창 *@
            <div class="input-group" style="width: 200px;">
                <input type="number" class="form-control" placeholder="문제 번호" 
                       @bind="jumpTarget" @onkeyup="HandleKeyUp" />
                <button class="btn btn-primary" @onclick="JumpToQuestion">이동</button>
            </div>
        </div>
    </div>

    @if (questions == null)
    {
        <div class="text-center">
            <div class="spinner-border" role="status"></div>
            <p>CSV 파일에서 문제를 읽어오는 중...</p>
        </div>
    }
    else
    {
        int listCount = 1;
        @foreach (var q in questions)
        {
            @* 각 문제 카드에 ID 부여 *@
            <div id="question-@listCount" class="card mb-4 shadow-sm border-@(q.IsSubmitted ? (q.SelectedKey == q.CorrectKey ? "success" : "danger") : "secondary")">
                <div class="card-body">
                    <h5 class="card-title">Q@(q.Id). @q.Title</h5>

                    <div class="list-group mt-3">
                        @foreach (var opt in q.Options)
                        {
                            <label class="list-group-item @(GetOptionClass(q, opt.Key))">
                                <input type="radio" name="question-@q.Id"
                           value="@opt.Key"
                           checked="@(q.SelectedKey == opt.Key)"
                           @onchange="@(() => q.SelectedKey = opt.Key)"
                           disabled="@q.IsSubmitted" />
                                <span class="ms-2"><strong>@opt.Key.</strong> @opt.Value</span>
                            </label>
                        }
                    </div>

                    @if (q.IsSubmitted)
                    {
                        <div class="alert @(q.SelectedKey == q.CorrectKey ? "alert-success" : "alert-danger") mt-3">
                            <p class="mb-0"><strong>💡 해설:</strong> @q.Explanation</p>
                        </div>
                    }

                    <div class="mt-3">
                        @if (!q.IsSubmitted)
                        {
                            <button class="btn btn-primary w-100" @onclick="() => q.IsSubmitted = true"
                        disabled="@(string.IsNullOrEmpty(q.SelectedKey))">
                                정답 확인
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary w-100" @onclick="() => ResetQuestion(q)">다시 풀기</button>
                        }
                    </div>
                </div>
            </div>
            listCount++;
        }
    }
</div>

@code {

    private int jumpTarget; // 입력받은 문제 번호

    // 엔터키 누르면 바로 이동하게 처리
    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await JumpToQuestion();
        }
    }

    // 입력된 번호로 스크롤 이동
    private async Task JumpToQuestion()
    {
        if (jumpTarget > 0)
        {
            // 리스트 카운트 기반 ID: "question-5" 형식으로 호출
            await JSRuntime.InvokeVoidAsync("scrollToElement", $"question-{jumpTarget}");
        }
    }

    public class QuestionModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = "";
        public Dictionary<string, string> Options { get; set; } = new();
        public string CorrectKey { get; set; } = "";
        public string Explanation { get; set; } = "";
        public string SelectedKey { get; set; } = "";
        public bool IsSubmitted { get; set; } = false;
    }

    private List<QuestionModel>? questions;

    protected override async Task OnInitializedAsync()
    {
        var absoluteUri = NavManager.ToAbsoluteUri("data/questions.csv").ToString();
        var csvData = await Http.GetStringAsync(absoluteUri);
        var lines = csvData.Split('\n').Skip(1);

        questions = new List<QuestionModel>();

        foreach (var line in lines)
        {
            if (string.IsNullOrWhiteSpace(line)) continue;

            // 파이썬에서 따옴표 없이 추출했으므로 단순 Split 가능
            var cols = line.Split(',');
            if (cols.Length < 8) continue;

            questions.Add(new QuestionModel
                {
                    Id = int.Parse(cols[0]),
                    Title = cols[1],
                    Options = new Dictionary<string, string> {
                    { "A", cols[2] }, { "B", cols[3] }, { "C", cols[4] }, { "D", cols[5] }
                },
                    CorrectKey = cols[6].Trim(), // CorrectKey 한 글자만 추출
                    Explanation = cols[7]
                });
        }
    }

    // 스크롤 이동 함수 (JS 호출)
    private async Task ScrollToQuestion(string elementId)
    {
        await JSRuntime.InvokeVoidAsync("scrollToElement", elementId);
    }

    private void ResetQuestion(QuestionModel q) => (q.SelectedKey, q.IsSubmitted) = ("", false);

    private string GetOptionClass(QuestionModel q, string key)
    {
        if (!q.IsSubmitted) return "";
        if (key == q.CorrectKey) return "list-group-item-success";
        if (q.SelectedKey == key && key != q.CorrectKey) return "list-group-item-danger";
        return "";
    }
}