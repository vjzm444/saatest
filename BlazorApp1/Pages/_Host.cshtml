@page "/"
@using Microsoft.AspNetCore.Components.Web
@namespace BlazorApp1.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="~/" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link href="css/site.css" rel="stylesheet" />
    <link href="BlazorApp1.styles.css" rel="stylesheet" />
    <link rel="icon" type="image/png" href="favicon.png"/>

    <style>
        /* 전체 페이지 레이아웃 보정 */
        .page {
            display: flex;
            flex-direction: row;
        }

        /* 사이드바: 왼쪽 끝으로 밀착 */
        .sidebar {
            width: 250px;
            min-height: 100vh;
            transition: all 0.3s ease-in-out;
            flex-shrink: 0;
            z-index: 1030; /* 상단바보다 위에 있게 설정 */
        }

            /* 접혔을 때: 완전히 왼쪽 밖으로 퇴출 */
            .sidebar.collapse {
                width: 0 !important;
                margin-left: -250px; /* 자신의 너비만큼 왼쪽으로 이동 */
                opacity: 0;
                visibility: hidden;
            }

        /* 메인 컨텐츠: 사이드바가 접히면 왼쪽 끝부터 시작 */
        main {
            flex: 1;
            min-width: 0;
            transition: all 0.3s ease-in-out;
        }

        /* 상단바 sticky 위치 고정 및 여백 제거 */
        .sticky-top {
            margin-left: 0 !important;
            margin-right: 0 !important;
            width: 100%;
        }

        /* 재연결 모달창(Attempting to reconnect...)을 완전히 숨김 */
        #components-reconnect-modal {
            display: none !important;
        }

        /* 연결 끊김 시 화면이 흐려지거나 클릭 막히는 오버레이 제거 */
        .components-reconnect-show,
        .components-reconnect-failed,
        .components-reconnect-rejected {
            display: none !important;
        }
    </style>

    <component type="typeof(HeadOutlet)" render-mode="ServerPrerendered" />
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>

    <script src="_framework/blazor.server.js"></script>
    <script>
        
        
        window.scrollToElement = (elementId) => {
            const element = document.getElementById(elementId);
            if (element) {
                element.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        };

        window.toggleAnswer = (element) => {
            if (window.event) window.event.stopPropagation();

            // 부모 카드를 찾아서 해설 섹션 타겟팅
            const card = element.closest('.card-body') || element.parentElement.parentElement;
            if (!card) return;

            const answerDiv = card.querySelector('.answer-section');

            if (answerDiv) {
                // 현재 상태가 안 보이면 보여주고, 보이면 숨기기
                if (answerDiv.style.display === 'none' || answerDiv.style.display === '') {
                    answerDiv.style.setProperty('display', 'block', 'important');
                    element.innerText = '해설 접기';
                    element.classList.replace('btn-primary', 'btn-outline-secondary');
                } else {
                    answerDiv.style.setProperty('display', 'none', 'important');
                    element.innerText = '정답 확인';
                    element.classList.replace('btn-outline-secondary', 'btn-primary');
                }
            }
        };

        window.resetAnswers = () => {
            // 1. 모든 해설 섹션을 다시 숨김
            const sections = document.querySelectorAll('.answer-section');
            sections.forEach(s => s.style.setProperty('display', 'none', 'important'));

            // 2. 모든 버튼 텍스트와 스타일을 초기 상태로 복구
            const buttons = document.querySelectorAll('.pure-js-btn');
            buttons.forEach(b => {
                b.innerText = '정답 확인';
                b.classList.remove('btn-outline-secondary');
                b.classList.add('btn-primary');
                b.style.display = 'block';
            });
        };

        window.clearQuizStorage = function () {
            localStorage.removeItem("quizAnswers");

            console.log("[CLEAR] quizAnswers 삭제됨");
            alert("리셋 완료되었습니다.");
        };


        //문제저장(오프라인 브라우저딴에서)
        window.quizStorage = {
            saveAnswer: function (questionId, selectedKey) {
                const data = JSON.parse(localStorage.getItem("quizAnswers") || "{}");

                data[questionId] = selectedKey;

                localStorage.setItem("quizAnswers", JSON.stringify(data));

                // ✅ 콘솔 로그
                console.log("[SAVE]", "Q" + questionId, "=>", selectedKey);
                console.log("[CURRENT STORAGE]", data);
            },

            loadAnswers: function () {
                const data = JSON.parse(localStorage.getItem("quizAnswers") || "{}");

                console.log("[LOAD]", data);

                return data;
            },

            clearAnswers: function () {
                localStorage.removeItem("quizAnswers");
                console.log("[CLEAR] 모든 데이터 삭제됨");
            }
        };

        window.saveAnswer = function (questionId, selectedKey) {
            const data = JSON.parse(localStorage.getItem("quizAnswers") || "{}");

            data[questionId] = selectedKey;

            localStorage.setItem("quizAnswers", JSON.stringify(data));

            console.log("[JS SAVE - OFFLINE OK]", "Q" + questionId, "=>", selectedKey);
        };
    </script>
</body>
</html>
